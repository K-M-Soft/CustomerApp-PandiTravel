# Database Configuration (Supabase PostgreSQL)
# Preferred: single URL
POSTGRES_URL=

# Alternative: discrete PostgreSQL values
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Email Configuration
# Choose provider: 'gmail' or 'smtp'
EMAIL_PROVIDER=gmail

# Gmail settings (if using Gmail)
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Generic SMTP settings (if not using Gmail)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# Sender email address
EMAIL_FROM=contact@pandi-travel.hu

# Admin email for booking notifications
ADMIN_EMAIL=contact@pandi-travel.hu

# Admin panel login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SESSION_SECRET=change-this-secret
